# Astro / Vite (optional overrides; defaults exist in code for Sanity project)
SITE_URL=http://localhost:4321
SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_API_VERSION=2024-01-01
# Server: draft perspective + Presentation (never expose to client bundles as PUBLIC_)
SANITY_READ_TOKEN=
SANITY_USE_CDN=true
SANITY_USE_MOCK=false
SANITY_PREVIEW_SECRET=

# Inquiry form → Resend → delivers to aboutPage.contact.email in Sanity
RESEND_API_KEY=
RESEND_FROM_EMAIL=
