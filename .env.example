# Sanity (optional overrides — defaults match repo)
SANITY_PROJECT_ID=yrca4rxr
SANITY_DATASET=production
SANITY_API_VERSION=2024-11-21

# Optional: set to "false" on CI/build so new publishes are visible immediately (not CDN cached)
# SANITY_USE_CDN=false

# Required on Vercel (Production + Preview) for Presentation: draft content + /api/preview/enable (validatePreviewUrl).
# Create a Viewer or Editor token in sanity.io/manage for this project’s dataset.
# SANITY_READ_TOKEN=

# Optional: manual preview without Presentation — call /api/preview/enable?secret=...&redirect=/
# SANITY_PREVIEW_SECRET=

# Force Astro to use mock projects (no API call)
# SANITY_USE_MOCK=true
