# Required if this Studio targets a different Sanity project than defaults:
# SANITY_PROJECT_ID=yourProjectId
# SANITY_DATASET=production
#
# Hosted Studio URL: https://<SANITY_STUDIO_HOST>.sanity.studio
# SANITY_STUDIO_HOST=photographer-a-studio
#
# Optional UI label shown in Studio:
# SANITY_STUDIO_TITLE=Photographer A Studio
#
# Site origin defaults used by Presentation:
# SANITY_SITE_ORIGIN_DEFAULT=https://photographer-a.example
# SANITY_STUDIO_PREVIEW_URL=https://photographer-a.example
# SANITY_STUDIO_ALLOW_ORIGINS=https://photographer-a.example,https://*.vercel.app
