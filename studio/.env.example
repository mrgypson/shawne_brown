# Origin of the Astro site (no trailing slash). Presentation loads this URL in the iframe.
# Local `sanity dev`: http://localhost:4321
# Production (required for hosted *.sanity.studio so clients are not sent to their own localhost):
#   https://your-project.vercel.app
SANITY_STUDIO_PREVIEW_URL=http://localhost:4321

# Comma-separated URLPattern strings. Required when preview runs on extra hosts (www, branch previews).
# Example: https://your-project.vercel.app,https://*.vercel.app
# SANITY_STUDIO_ALLOW_ORIGINS=

# Hosted Studio: copy the two vars above into Sanity Manage → Project → Environment variables,
# then run `npm run deploy` from this folder so the deploy bundle picks them up.
