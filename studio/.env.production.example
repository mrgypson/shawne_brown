# Copy to `.env.production` in this folder (same directory as sanity.config.ts).
# `sanity deploy` / `npm run deploy` load `.env.production` in production mode and bake
# these into the hosted Studio bundle. They are NOT set in Sanity Manage like Vercel.

SANITY_STUDIO_PREVIEW_URL=https://shawne-brown.vercel.app
SANITY_STUDIO_ALLOW_ORIGINS=https://shawne-brown.vercel.app,https://*.vercel.app
