---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { siteConfig } from '../../data/mock/site';
import { getProjects, getWorkPage } from '../../lib/content';

export const prerender = false;

const useDraftPerspective = Boolean(Astro.locals.sanityDraftPerspective);
const [projects, workPage] = await Promise.all([
	getProjects({ preview: useDraftPerspective }),
	getWorkPage({ preview: useDraftPerspective }),
]);

const resolvedTitle = workPage.title?.trim() || 'Work';
const showTitle = workPage.showTitle && Boolean(resolvedTitle);
const showSubheading = workPage.showSubheading && Boolean(workPage.subheading?.trim());
const showHeader = showTitle || showSubheading;

const title = resolvedTitle;
const description = `Selected projects and series by ${siteConfig.siteTitle}.`;
---

<BaseLayout title={title} description={description}>
	{showHeader && (
		<header class="prose-narrow">
			{showTitle && <h1 class="page-title">{resolvedTitle}</h1>}
			{showSubheading && <p class="page-lede">{workPage.subheading}</p>}
		</header>
	)}
	<div class="work-grid">
		{
			projects.map((project) => (
				<a class="work-item" href={`/work/${project.slug}`} data-testid={`work-index-${project.slug}`}>
					<figure class="work-item-figure">
						<img
							src={project.coverImage.src}
							alt={project.coverImage.alt}
							loading="lazy"
							decoding="async"
							sizes="(min-width: 40rem) 50vw, 100vw"
							width="960"
							height="720"
						/>
						<div class="work-item-overlay">
							<h2 class="work-item-title">{project.title}</h2>
						</div>
					</figure>
				</a>
			))
		}
	</div>
</BaseLayout>
