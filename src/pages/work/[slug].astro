---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectGallery from '../../components/ProjectGallery.astro';
import { siteConfig } from '../../data/mock/site';
import { getProjectBySlug } from '../../lib/content';
import { isNeuhoffProject } from '../../types/project';
import type { Project } from '../../types/project';

export const prerender = false;

const useDraftPerspective = Boolean(Astro.locals.sanityDraftPerspective);
const slug = Astro.params.slug;
const project: Project | undefined = slug
	? await getProjectBySlug(slug, { preview: useDraftPerspective })
	: undefined;

if (!project) {
	return Astro.redirect('/404');
}

const title = project.title;
const description = project.shortDescription;
const showPrintMeta = isNeuhoffProject(project);
---

<BaseLayout title={title} description={description}>
	<article>
		<header class="prose-narrow">
			<h1 class="page-title">{project.title}</h1>
			<p class="text-muted project-header-year">{project.yearLabel}</p>
			<p class="page-lede project-header-lede">{project.shortDescription}</p>
			{project.longDescription && <p class="prose-narrow project-header-long">{project.longDescription}</p>}
		</header>

		{
			showPrintMeta && (
				<div class="neuhoff-note prose-narrow" role="note" data-testid="neuhoff-print-note">
					<strong>{siteConfig.siteTitle} — edition structure</strong>
					<p>
						This series may include limited editions and print sales. Availability, sizing, and framing below are
						placeholder fields for a future inquiry flow — no purchases are processed on this site yet.
					</p>
				</div>
			)
		}

		<ProjectGallery images={project.images} showPrintMeta={showPrintMeta} layout="single" />
	</article>
</BaseLayout>
