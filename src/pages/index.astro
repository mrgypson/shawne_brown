---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../data/mock/site';
import { getProjects } from '../lib/content';

/** Server-rendered so Presentation + `/api/preview/enable` can swap in draft content without a separate preview build. */
export const prerender = false;

const title = siteConfig.siteTitle;
const description = siteConfig.defaultDescription;
const usePreview = Boolean(Astro.locals.sanityPreview);
const projects = await getProjects({ preview: usePreview });
---

<BaseLayout title={title} description={description}>
	<section class="home-projects" aria-labelledby="home-heading">
		<h1 id="home-heading" class="visually-hidden">{title}</h1>
		<ul class="home-project-list">
			{
				projects.map((project) => (
					<li>
						<a
							href={`/work/${project.slug}`}
							class="home-project-link"
							data-testid={`home-project-${project.slug}`}
						>
							{project.title}
						</a>
					</li>
				))
			}
		</ul>
	</section>
</BaseLayout>
