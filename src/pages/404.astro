---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../data/mock/site';

/** Server-rendered so BaseLayout can load contact/footer without prerender header limitations. */
export const prerender = false;

const title = 'Page not found';
const description = `The requested page could not be found — ${siteConfig.siteTitle}.`;
---

<BaseLayout title={title} description={description}>
	<section class="prose-narrow">
		<h1 class="page-title">Page not found</h1>
		<p class="page-lede">This URL does not match a page on this site.</p>
		<p>
			<a href="/">Return home</a>
			<span class="text-muted"> · </span>
			<a href="/work">View work</a>
		</p>
	</section>
</BaseLayout>
