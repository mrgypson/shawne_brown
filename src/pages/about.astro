---
import BaseLayout from '../layouts/BaseLayout.astro';
import { instagramHref, websiteHref } from '../lib/contact/socialUrls';
import { siteConfig } from '../data/mock/site';
import { getAbout, getSiteSettings } from '../lib/content';

export const prerender = false;

const useDraftPerspective = Boolean(Astro.locals.sanityDraftPerspective);
const [about, siteSettings] = await Promise.all([
	getAbout({ preview: useDraftPerspective }),
	getSiteSettings({ preview: useDraftPerspective }),
]);
const title = 'About';
const siteName = siteSettings.siteName || siteConfig.siteName;
const description = `Artist biography and contact for ${siteName}.`;
const ig = instagramHref(about.contact.instagram);
const web = websiteHref(about.contact.website);
---

<BaseLayout title={title} description={description}>
	<header class="prose-narrow">
		<h1 class="page-title">About</h1>
	</header>

	<section class="prose-narrow page-section" aria-labelledby="about-bio-heading">
		<h2 id="about-bio-heading" class="page-section-heading">Biography</h2>
		<p class="page-section-body">{about.bio}</p>
	</section>

	{
		about.statement && (
			<section class="prose-narrow page-section" aria-labelledby="about-statement-heading">
				<h2 id="about-statement-heading" class="page-section-heading">Statement</h2>
				<p class="page-section-body page-section-body--pre">{about.statement}</p>
			</section>
		)
	}

	<section class="prose-narrow page-section" aria-labelledby="about-exhibitions-heading">
		<h2 id="about-exhibitions-heading" class="page-section-heading">Exhibitions &amp; publications</h2>
		<ul class="exhibitions-list">
			{about.exhibitions.map((entry) => (
				<li>
					<span class="text-muted">{entry.year}</span> — {entry.detail}
				</li>
			))}
		</ul>
		{about.publicationsNote && <p class="text-muted page-section-body publications-note">{about.publicationsNote}</p>}
	</section>

	<section class="prose-narrow contact-block" aria-labelledby="about-contact-heading">
		<h2 id="about-contact-heading" class="page-section-heading">Contact</h2>
		<ul class="contact-list">
			<li>
				<a href={`mailto:${about.contact.email}`} data-testid="about-mailto">{about.contact.email}</a>
			</li>
			{about.contact.location && <li class="text-muted">{about.contact.location}</li>}
			{
				about.contact.instagram && (
					<li>
						{ig ? (
							<a href={ig} rel="noopener noreferrer me" target="_blank" data-testid="about-instagram-link">
								Instagram
							</a>
						) : (
							<span class="text-muted">{about.contact.instagram}</span>
						)}
					</li>
				)
			}
			{
				about.contact.website && (
					<li>
						{web ? (
							<a href={web} rel="noopener noreferrer me" target="_blank" data-testid="about-website-link">
								Website
							</a>
						) : (
							<span class="text-muted">{about.contact.website}</span>
						)}
					</li>
				)
			}
		</ul>
	</section>
</BaseLayout>
