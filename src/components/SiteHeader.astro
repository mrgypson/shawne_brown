---
import { siteConfig } from '../data/mock/site';
import { getProjects, getSiteSettings } from '../lib/content';

const pathname = Astro.url.pathname;
const useDraftPerspective = Boolean(Astro.locals.sanityDraftPerspective);
const [projects, siteSettings] = await Promise.all([
	getProjects({ preview: useDraftPerspective }),
	getSiteSettings({ preview: useDraftPerspective }),
]);

function isActive(href: string): boolean {
	if (href === '/') {
		return pathname === '/';
	}
	return pathname === href || pathname.startsWith(`${href}/`);
}

const secondaryLinks = [
	{ href: '/about', label: 'About' },
	{ href: '/contact', label: 'Contact' },
] as const;

const workIsActive = pathname.startsWith('/work/');
---

<header class="site-header" id="site-header">
	<p class="site-title">
		<a href="/" id="site-header-title" data-testid="site-header-title-link">
			{siteSettings.siteName || siteConfig.siteName}
		</a>
	</p>
	<button
		type="button"
		class="site-nav-toggle"
		id="site-header-menu-toggle"
		aria-expanded="false"
		aria-controls="site-header-nav"
		data-testid="site-header-menu-toggle"
	>
		<span class="visually-hidden">Menu</span>
		<span class="site-nav-toggle-bar" aria-hidden="true"></span>
		<span class="site-nav-toggle-bar" aria-hidden="true"></span>
		<span class="site-nav-toggle-bar" aria-hidden="true"></span>
	</button>
	<nav class="site-nav" aria-label="Primary" id="site-header-nav" data-testid="site-header-nav">
		<div class="site-nav-item site-nav-item--work" id="site-header-work">
			<button
				type="button"
				class="site-nav-trigger"
				id="site-header-work-trigger"
				aria-haspopup="menu"
				aria-expanded="false"
				aria-controls="site-header-work-menu"
				aria-current={workIsActive ? 'page' : undefined}
				data-testid="site-header-link-work"
			>
				Work
			</button>
			<ul
				class="site-nav-submenu"
				id="site-header-work-menu"
				role="menu"
				aria-labelledby="site-header-work-trigger"
				hidden
			>
				{
					projects.map((project) => (
						<li role="none">
							<a
								role="menuitem"
								href={`/work/${project.slug}`}
								aria-current={pathname === `/work/${project.slug}` ? 'page' : undefined}
								data-testid={`site-header-work-item-${project.slug}`}
							>
								{project.title}
							</a>
						</li>
					))
				}
			</ul>
		</div>
		{
			secondaryLinks.map(({ href, label }) => (
				<a
					href={href}
					aria-current={isActive(href) ? 'page' : undefined}
					data-testid={`site-header-link-${label.toLowerCase()}`}
				>
					{label}
				</a>
			))
		}
	</nav>
</header>

<script>
	(function () {
		const header = document.getElementById('site-header');
		const toggle = document.getElementById('site-header-menu-toggle');
		const nav = document.getElementById('site-header-nav');
		const workWrap = document.getElementById('site-header-work');
		const workTrigger = document.getElementById('site-header-work-trigger');
		const workMenu = document.getElementById('site-header-work-menu');
		if (!header || !toggle || !nav || !workWrap || !workTrigger || !workMenu) return;
		const headerEl = header;
		const toggleEl = toggle;
		const navEl = nav;
		const workWrapEl = workWrap;
		const workTriggerEl = workTrigger;
		const workMenuEl = workMenu;

		const desktopMq = window.matchMedia('(min-width: 48rem)');

		function setSubmenuOpen(open: boolean) {
			workTriggerEl.setAttribute('aria-expanded', String(open));
			if (open) {
				workMenuEl.removeAttribute('hidden');
			} else {
				workMenuEl.setAttribute('hidden', '');
			}
		}

		function setNavOpen(open: boolean) {
			headerEl.classList.toggle('site-header--nav-open', open);
			toggleEl.setAttribute('aria-expanded', String(open));
			if (!open) setSubmenuOpen(false);
		}

		toggleEl.addEventListener('click', () => {
			setNavOpen(!headerEl.classList.contains('site-header--nav-open'));
		});

		workTriggerEl.addEventListener('click', (e) => {
			e.stopPropagation();
			const isOpen = workTriggerEl.getAttribute('aria-expanded') === 'true';
			setSubmenuOpen(!isOpen);
		});

		workMenuEl.querySelectorAll('a').forEach((link) => {
			link.addEventListener('click', () => {
				setSubmenuOpen(false);
				setNavOpen(false);
			});
		});

		navEl.querySelectorAll(':scope > a').forEach((link) => {
			link.addEventListener('click', () => setNavOpen(false));
		});

		document.addEventListener('click', (e) => {
			const target = e.target;
			if (!target) return;
			if (!(target instanceof Node)) return;
			if (!workWrapEl.contains(target)) {
				setSubmenuOpen(false);
			}
		});

		document.addEventListener('keydown', (e) => {
			if (e.key === 'Escape') {
				setSubmenuOpen(false);
				setNavOpen(false);
			}
		});

		function onViewportChange() {
			if (desktopMq.matches) setNavOpen(false);
			setSubmenuOpen(false);
		}
		desktopMq.addEventListener('change', onViewportChange);
	})();
</script>
