---
import { siteConfig } from '../data/mock/site';

const pathname = Astro.url.pathname;

function isActive(href: string): boolean {
	if (href === '/') {
		return pathname === '/';
	}
	return pathname === href || pathname.startsWith(`${href}/`);
}

const links = [
	{ href: '/work', label: 'Work' },
	{ href: '/about', label: 'About' },
	{ href: '/contact', label: 'Contact' },
] as const;
---

<header class="site-header" id="site-header">
	<p class="site-title">
		<a href="/" id="site-header-title" data-testid="site-header-title-link">{siteConfig.siteTitle}</a>
	</p>
	<button
		type="button"
		class="site-nav-toggle"
		id="site-header-menu-toggle"
		aria-expanded="false"
		aria-controls="site-header-nav"
		data-testid="site-header-menu-toggle"
	>
		<span class="visually-hidden">Menu</span>
		<span class="site-nav-toggle-bar" aria-hidden="true"></span>
		<span class="site-nav-toggle-bar" aria-hidden="true"></span>
		<span class="site-nav-toggle-bar" aria-hidden="true"></span>
	</button>
	<nav class="site-nav" aria-label="Primary" id="site-header-nav" data-testid="site-header-nav">
		{
			links.map(({ href, label }) => (
				<a href={href} aria-current={isActive(href) ? 'page' : undefined} data-testid={`site-header-link-${label.toLowerCase()}`}>
					{label}
				</a>
			))
		}
	</nav>
</header>

<script>
	(function () {
		const header = document.getElementById('site-header');
		const toggle = document.getElementById('site-header-menu-toggle');
		const nav = document.getElementById('site-header-nav');
		if (!header || !toggle || !nav) return;

		const desktopMq = window.matchMedia('(min-width: 48rem)');

		function setNavOpen(open) {
			header.classList.toggle('site-header--nav-open', open);
			toggle.setAttribute('aria-expanded', String(open));
		}

		toggle.addEventListener('click', () => {
			setNavOpen(!header.classList.contains('site-header--nav-open'));
		});

		nav.querySelectorAll('a').forEach((link) => {
			link.addEventListener('click', () => setNavOpen(false));
		});

		document.addEventListener('keydown', (e) => {
			if (e.key === 'Escape') setNavOpen(false);
		});

		function onViewportChange() {
			if (desktopMq.matches) setNavOpen(false);
		}
		desktopMq.addEventListener('change', onViewportChange);
	})();
</script>
