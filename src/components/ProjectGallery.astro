---
import type { GalleryImage, GallerySpacingStep } from '../types/project';
import type { NeuhoffImage } from '../types/neuhoff';
import GalleryFigure from './GalleryFigure.astro';

interface Props {
	images: (GalleryImage | NeuhoffImage)[];
	/** When true (e.g. Neuhoff), show optional print-sales metadata blocks. */
	showPrintMeta?: boolean;
	layout?: 'single' | 'two-up';
	/** Gallery-wide vertical gap between rows (0–4). */
	spaceBetween?: GallerySpacingStep;
	/** Gap inside every pair — desktop column gap and mobile stack gap (0–4). */
	pairGap?: GallerySpacingStep;
}

const {
	images,
	showPrintMeta = false,
	layout = 'single',
	spaceBetween = 3,
	pairGap = 2,
} = Astro.props;

type Row =
	| { kind: 'solo'; image: GalleryImage | NeuhoffImage; index: number }
	| {
			kind: 'pair';
			left: GalleryImage | NeuhoffImage;
			right: GalleryImage | NeuhoffImage;
			leftIndex: number;
			rightIndex: number;
	  };

const rows: Row[] = [];
for (let i = 0; i < images.length; i += 1) {
	const current = images[i];
	const next = images[i + 1];
	if (current.pairWithNext && next) {
		rows.push({ kind: 'pair', left: current, right: next, leftIndex: i, rightIndex: i + 1 });
		i += 1;
	} else {
		rows.push({ kind: 'solo', image: current, index: i });
	}
}
---

<div
	class:list={['project-gallery', layout === 'two-up' && 'project-gallery--two-up']}
	id="project-gallery"
	data-testid="project-gallery"
	data-space-between={String(spaceBetween)}
>
	{
		rows.map((row, rowIndex) =>
			row.kind === 'solo' ? (
				<GalleryFigure image={row.image} index={row.index} showPrintMeta={showPrintMeta} />
			) : (
				<div
					class="gallery-pair"
					data-testid={`project-gallery-pair-${rowIndex}`}
					data-pair-gap={String(pairGap)}
					data-ratio={row.left.pairRatio ?? '50/50'}
					data-align-v={row.left.pairAlignVertical ?? 'top'}
				>
					<GalleryFigure
						image={row.left}
						index={row.leftIndex}
						showPrintMeta={showPrintMeta}
						paired
					/>
					<GalleryFigure
						image={row.right}
						index={row.rightIndex}
						showPrintMeta={showPrintMeta}
						paired
					/>
				</div>
			),
		)
	}
</div>

<script>
	// Fallback fade-in for browsers without CSS scroll-driven animations.
	// When `animation-timeline: view()` is supported, CSS drives the effect
	// and this observer is a no-op.
	const supportsViewTimeline =
		typeof CSS !== 'undefined' && CSS.supports('animation-timeline: view()');

	if (!supportsViewTimeline) {
		const figures = document.querySelectorAll<HTMLElement>(
			'.project-gallery .gallery-figure',
		);

		const prefersReducedMotion = window.matchMedia(
			'(prefers-reduced-motion: reduce)',
		).matches;

		if (prefersReducedMotion) {
			figures.forEach((figure) => figure.classList.add('is-revealed'));
		} else {
			const observer = new IntersectionObserver(
				(entries) => {
					entries.forEach((entry) => {
						if (entry.isIntersecting) {
							entry.target.classList.add('is-revealed');
							observer.unobserve(entry.target);
						}
					});
				},
				{ rootMargin: '0px 0px -10% 0px', threshold: 0.1 },
			);

			figures.forEach((figure) => observer.observe(figure));
		}
	}
</script>
