---
import type { GalleryImage, GallerySpacingStep } from '../types/project';
import type { NeuhoffImage } from '../types/neuhoff';
import GalleryFigure from './GalleryFigure.astro';

interface Props {
	images: (GalleryImage | NeuhoffImage)[];
	/** When true (e.g. Neuhoff), show optional print-sales metadata blocks. */
	showPrintMeta?: boolean;
	layout?: 'single' | 'two-up';
	/** Gallery-wide vertical gap between rows (0–4). */
	spaceBetween?: GallerySpacingStep;
	/** Gap inside every pair — horizontal gap between the two columns (0–4). */
	pairGap?: GallerySpacingStep;
}

const {
	images,
	showPrintMeta = false,
	layout = 'single',
	spaceBetween = 3,
	pairGap = 2,
} = Astro.props;

type Row =
	| { kind: 'solo'; image: GalleryImage | NeuhoffImage; index: number }
	| {
			kind: 'pair';
			left: GalleryImage | NeuhoffImage;
			right: GalleryImage | NeuhoffImage;
			leftIndex: number;
			rightIndex: number;
	  };

const rows: Row[] = [];
for (let i = 0; i < images.length; i += 1) {
	const current = images[i];
	const next = images[i + 1];
	if (current.pairWithNext && next) {
		rows.push({ kind: 'pair', left: current, right: next, leftIndex: i, rightIndex: i + 1 });
		i += 1;
	} else {
		rows.push({ kind: 'solo', image: current, index: i });
	}
}
---

<div
	class:list={['project-gallery', layout === 'two-up' && 'project-gallery--two-up']}
	id="project-gallery"
	data-testid="project-gallery"
	data-space-between={String(spaceBetween)}
>
	{
		rows.map((row, rowIndex) =>
			row.kind === 'solo' ? (
				<GalleryFigure image={row.image} index={row.index} showPrintMeta={showPrintMeta} />
			) : (
				<div
					class="gallery-pair"
					data-testid={`project-gallery-pair-${rowIndex}`}
					data-pair-gap={String(pairGap)}
					data-ratio={row.left.pairRatio ?? '50/50'}
					data-align-v={row.left.pairAlignVertical ?? 'top'}
				>
					<GalleryFigure
						image={row.left}
						index={row.leftIndex}
						showPrintMeta={showPrintMeta}
						paired
					/>
					<GalleryFigure
						image={row.right}
						index={row.rightIndex}
						showPrintMeta={showPrintMeta}
						paired
					/>
				</div>
			),
		)
	}
</div>

<script>
	const supportsViewTimeline =
		typeof CSS !== 'undefined' && CSS.supports('animation-timeline: view()');
	const prefersReducedMotion = window.matchMedia(
		'(prefers-reduced-motion: reduce)',
	).matches;

	// Keep initial navigation pinned to top; enable snap only after real scroll intent.
	const root = document.documentElement;
	const enableSnapAfterIntent = () => {
		if (root.classList.contains('project-gallery-snap-active')) return;
		root.classList.add('project-gallery-snap-active');
		window.removeEventListener('wheel', enableSnapAfterIntent);
		window.removeEventListener('touchmove', enableSnapAfterIntent);
		window.removeEventListener('keydown', onSnapIntentKey);
	};
	const onSnapIntentKey = (event: KeyboardEvent) => {
		const scrollKeys = new Set([
			'ArrowDown',
			'ArrowUp',
			'PageDown',
			'PageUp',
			'Home',
			'End',
			' ',
		]);
		if (!scrollKeys.has(event.key)) return;
		enableSnapAfterIntent();
	};
	window.addEventListener('wheel', enableSnapAfterIntent, { passive: true });
	window.addEventListener('touchmove', enableSnapAfterIntent, { passive: true });
	window.addEventListener('keydown', onSnapIntentKey);

	const IDLE_DELAY_MS = 900;

	document.querySelectorAll<HTMLElement>('.project-gallery').forEach((gallery) => {
		const figures = Array.from(
			gallery.querySelectorAll<HTMLElement>('.gallery-figure'),
		);
		if (figures.length === 0) return;

		// Browsers without view-timeline support: one-shot fade-in via IO.
		if (!supportsViewTimeline) {
			if (prefersReducedMotion) {
				figures.forEach((f) => f.classList.add('is-revealed'));
			} else {
				const revealObserver = new IntersectionObserver(
					(entries) => {
						entries.forEach((entry) => {
							if (entry.isIntersecting) {
								entry.target.classList.add('is-revealed');
								revealObserver.unobserve(entry.target);
							}
						});
					},
					{ rootMargin: '0px 0px -10% 0px', threshold: 0.1 },
				);
				figures.forEach((f) => revealObserver.observe(f));
			}
		}

		// Reduced-motion users opt out of the linger-to-focus effect.
		if (prefersReducedMotion) return;

		let idleTimer: ReturnType<typeof setTimeout> | undefined;

		const clearFocus = () => {
			figures.forEach((f) => f.classList.remove('is-focused'));
		};

		const findCenteredFigure = (): HTMLElement | null => {
			const viewportCenter = window.innerHeight / 2;
			let closest: HTMLElement | null = null;
			let minDist = Infinity;
			for (const fig of figures) {
				const rect = fig.getBoundingClientRect();
				if (rect.bottom < 0 || rect.top > window.innerHeight) continue;
				const center = rect.top + rect.height / 2;
				const dist = Math.abs(center - viewportCenter);
				if (dist < minDist) {
					minDist = dist;
					closest = fig;
				}
			}
			return closest;
		};

		const enterIdle = () => {
			const focused = findCenteredFigure();
			if (!focused) return;
			clearFocus();
			// When the focused figure is part of a pair, keep both siblings
			// lit so the composed row reads as a single subject.
			const pair =
				focused.classList.contains('gallery-figure--paired') &&
				focused.parentElement?.classList.contains('gallery-pair')
					? focused.parentElement
					: null;
			if (pair) {
				pair
					.querySelectorAll<HTMLElement>('.gallery-figure')
					.forEach((f) => f.classList.add('is-focused'));
			} else {
				focused.classList.add('is-focused');
			}
			gallery.classList.add('is-idle');
		};

		const exitIdle = () => {
			if (idleTimer) {
				clearTimeout(idleTimer);
				idleTimer = undefined;
			}
			gallery.classList.remove('is-idle');
			clearFocus();
		};

		const scheduleIdle = () => {
			exitIdle();
			idleTimer = setTimeout(enterIdle, IDLE_DELAY_MS);
		};

		window.addEventListener('scroll', scheduleIdle, { passive: true });
		// Cancel pending idle if the user navigates away via tab/blur so we
		// don't lock in a stale focused state when they return.
		window.addEventListener('blur', exitIdle);
	});
</script>
