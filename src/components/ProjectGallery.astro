---
import type { GalleryImage } from '../types/project';
import type { NeuhoffImage } from '../types/neuhoff';
import GalleryFigure from './GalleryFigure.astro';

interface Props {
	images: (GalleryImage | NeuhoffImage)[];
	/** When true (e.g. Neuhoff), show optional print-sales metadata blocks. */
	showPrintMeta?: boolean;
	layout?: 'single' | 'two-up';
}

const { images, showPrintMeta = false, layout = 'single' } = Astro.props;

type Row =
	| { kind: 'solo'; image: GalleryImage | NeuhoffImage; index: number }
	| {
			kind: 'pair';
			left: GalleryImage | NeuhoffImage;
			right: GalleryImage | NeuhoffImage;
			leftIndex: number;
			rightIndex: number;
	  };

const rows: Row[] = [];
for (let i = 0; i < images.length; i += 1) {
	const current = images[i];
	const next = images[i + 1];
	if (current.pairWithNext && next) {
		rows.push({ kind: 'pair', left: current, right: next, leftIndex: i, rightIndex: i + 1 });
		i += 1;
	} else {
		rows.push({ kind: 'solo', image: current, index: i });
	}
}
---

<div
	class:list={['project-gallery', layout === 'two-up' && 'project-gallery--two-up']}
	id="project-gallery"
	data-testid="project-gallery"
>
	{
		rows.map((row, rowIndex) =>
			row.kind === 'solo' ? (
				<GalleryFigure
					image={row.image}
					index={row.index}
					showPrintMeta={showPrintMeta}
				/>
			) : (
				<div
					class="gallery-pair"
					data-testid={`project-gallery-pair-${rowIndex}`}
					data-space-above={String(row.left.spaceAbove ?? 0)}
					data-space-below={String(row.right.spaceBelow ?? row.left.spaceBelow ?? 3)}
				>
					<GalleryFigure
						image={row.left}
						index={row.leftIndex}
						showPrintMeta={showPrintMeta}
						paired
					/>
					<GalleryFigure
						image={row.right}
						index={row.rightIndex}
						showPrintMeta={showPrintMeta}
						paired
					/>
				</div>
			),
		)
	}
</div>
