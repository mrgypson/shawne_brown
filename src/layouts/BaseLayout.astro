---
import '../styles/global.css';
import SanityVisualEditing from '../components/SanityVisualEditing.astro';
import SeoHead from '../components/SeoHead.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { siteConfig } from '../data/mock/site';
import { getAbout, getSiteSettings } from '../lib/content';

interface Props {
	title: string;
	description: string;
	ogImage?: string;
}

const { title, description, ogImage } = Astro.props;
const useDraftPerspective = Boolean(Astro.locals.sanityDraftPerspective);
const [about, siteSettings] = await Promise.all([
	getAbout({ preview: useDraftPerspective }),
	getSiteSettings({ preview: useDraftPerspective }),
]);
const sanityPreview = Boolean(Astro.locals.sanityPreview);
const visualEditingEnabled =
	sanityPreview || Astro.url.searchParams.has('sanity-preview-perspective');
const pageTitle =
	title.includes(siteSettings.siteName) ? title : `${title} — ${siteSettings.siteName}`;
const pageDescription = description || siteSettings.defaultDescription || siteConfig.defaultDescription;
const pageOgImage = ogImage || siteSettings.defaultOgImageUrl;
const faviconHref = siteSettings.faviconUrl || siteConfig.faviconUrl || '/favicon.svg';
---

<!doctype html>
<html lang="en">
	<head>
		<link rel="icon" href={faviconHref} />
		<SeoHead title={pageTitle} description={pageDescription} ogImage={pageOgImage} />
	</head>
	<body>
		<a class="skip-link" href="#main-content">Skip to content</a>
		<div class="layout-main">
			<SiteHeader />
			<main id="main-content">
				<slot />
			</main>
			<SiteFooter contact={about.contact} />
		</div>
		<SanityVisualEditing enabled={visualEditingEnabled} />
	</body>
</html>
